# Host project
DATABASE_URL=postgresql://user:pass@host:port/products_db

# spec_filler / spec_ranker: choose ONE of the two Gemini backends.

# Option A: AI Studio (requires GEMINI_API_KEY)
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI (requires `gcloud auth application-default login` + a GCP project)
USE_VERTEX_AI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: dedicated Postgres for spec_filler / spec_ranker run history.
# Leave unset to skip DB logging (non-fatal).
SPEC_LOG_DATABASE_URL=postgresql://user:pass@host:port/agent_logs_db
